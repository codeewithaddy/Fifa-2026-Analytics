# ── Virtual environment ──
venv/

# ── Python cache ──
__pycache__/
*.py[cod]
*$py.class

# ── Kaggle API credentials (NEVER commit) ──
kaggle.json

# ── Environment variables ──
.env

# ── Data files (auto-refreshed via Kaggle API) ──
data/

